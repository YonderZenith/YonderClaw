{
  "name": "swarm",
  "displayName": "QIS Intelligence Network",
  "version": "1.0.0",
  "description": "Shared intelligence buckets — local personal swarm + global YonderClaw network. The QIS proof of concept.",
  "category": "intelligence",
  "alwaysInstall": true,
  "engines": { "yonderclaw": ">=1.0.0" },
  "requires": { "modules": ["core"] },
  "contributes": {
    "swarm": {
      "types.ts.txt": "swarm/types.ts",
      "swarm-client.ts.txt": "swarm/swarm-client.ts",
      "relay-server.ts.txt": "swarm/relay-server.ts",
      "dht-client.ts.txt": "swarm/dht-client.ts",
      "qis-identity.ts.txt": "swarm/qis-identity.ts",
      "qis-config.ts.txt": "swarm/qis-config.ts",
      "qis-write-control.ts.txt": "swarm/qis-write-control.ts",
      "qis-sync.ts.txt": "swarm/qis-sync.ts",
      "qis-client.ts.txt": "swarm/qis-client.ts"
    },
    "npmScripts": {
      "swarm-relay": "tsx swarm/relay-server.ts",
      "swarm-stats": "tsx swarm/relay-server.ts --port 7891"
    },
    "claudeMd": ["swarm"],
    "directories": ["swarm"]
  },
  "placeholders": ["__AGENT_NAME__", "__ENABLE_LOCAL__", "__ENABLE_GLOBAL__", "__RELAY_URL__", "__AGENT_DOMAIN__"]
}
